{
  "expo": {
    "name": "VizMinder MAD",
    "slug": "vizminder-mad",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "VizMinder uses the camera so reminders can include visual context.",
        "NSPhotoLibraryUsageDescription": "VizMinder uses your photo library so reminders can include visual context."
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ]
  }
}
